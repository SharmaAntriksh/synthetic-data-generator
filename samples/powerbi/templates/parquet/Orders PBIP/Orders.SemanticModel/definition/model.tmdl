model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Parameters & Functions'

	annotation PBI_QueryGroupOrder = 0

queryGroup Dimensions

	annotation PBI_QueryGroupOrder = 1

queryGroup Fact

	annotation PBI_QueryGroupOrder = 4

queryGroup Dimensions\Products

	annotation PBI_QueryGroupOrder = 0

queryGroup Dimensions\Customer

	annotation PBI_QueryGroupOrder = 1

queryGroup Fact\Sales

	annotation PBI_QueryGroupOrder = 0

queryGroup Fact\ExchangeRates

	annotation PBI_QueryGroupOrder = 1

queryGroup Fact\Budget

	annotation PBI_QueryGroupOrder = 2

queryGroup Fact\SecondaryFacts

	annotation PBI_QueryGroupOrder = 3

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["ContosoFolder","FxReadParquetFile","Products","ProductSubcategory","ProductCategory","Supplier","ProductProfile","Customer","PlanSubscription","Plan","CustomerProfile","OrganizationProfile","LoyaltyTiers","AcquisitionChannel","Dates","Store","Promotion","Geography","Currency","Employee","EmployeeStoreAssignment","ReturnReason","Channel","Time","Warehouse","ExchangeRate","ExchangeRateMonthly","OrderHeader","OrderDetail","Returns","Budget","BudgetMonthly","Inventory","Wishlist","Complaints","MeasureTable"]

annotation PBI_ProTooling = ["TMDLView_Desktop","DevMode"]

ref table Products
ref table ProductSubcategory
ref table ProductCategory
ref table Supplier
ref table ProductProfile
ref table Customer
ref table PlanSubscription
ref table Plan
ref table CustomerProfile
ref table OrganizationProfile
ref table LoyaltyTiers
ref table AcquisitionChannel
ref table Dates
ref table Store
ref table Promotion
ref table Geography
ref table Currency
ref table Employee
ref table EmployeeStoreAssignment
ref table ReturnReason
ref table Channel
ref table Time
ref table Warehouse
ref table ExchangeRate
ref table ExchangeRateMonthly
ref table OrderHeader
ref table OrderDetail
ref table Returns
ref table Budget
ref table BudgetMonthly
ref table Inventory
ref table Wishlist
ref table Complaints
ref table MeasureTable

ref cultureInfo en-US

