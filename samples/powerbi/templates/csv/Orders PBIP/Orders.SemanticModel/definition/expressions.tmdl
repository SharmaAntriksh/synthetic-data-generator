expression ContosoFolder = "C:\Users\antsharma\Downloads\synthetic-data-generator\generated_datasets\2026-03-30 05_06_26 PM Customers 43K Sales 1M CSV" meta [IsParameterQuery=true, Type="Any", IsParameterQueryRequired=true]
	lineageTag: d1991dc0-64f4-4dae-a1e5-e0122e047e51
	queryGroup: 'Parameters & Functions'

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Text

expression FxReadCSVFile = ```
		( 
		    TableType as text, 
		    FileName as text
		) as table =>
		    let 
		        FileContents = 
		            File.Contents ( ContosoFolder & "\" & TableType & "\" & FileName & ".csv" ),
		        CsvDocument = 
		            Csv.Document(
		                FileContents,
		                [Delimiter=",", Encoding=1252, QuoteStyle=QuoteStyle.None]
		            ),
		        PromoteHeaders = Table.PromoteHeaders ( CsvDocument, [ PromoteAllScalars = true ] )
		    in 
		        PromoteHeaders
		```
	lineageTag: d2ba962f-2339-4f99-977a-ef51cbe9f4db
	queryGroup: 'Parameters & Functions'

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Function

